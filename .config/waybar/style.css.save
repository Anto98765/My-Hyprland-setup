@import "colors.css";


* {
    border: none;
    border-radius: 0;
    font-family: Roboto,  "Fira Sans Semibold", "Font Awesome 7 Free", "Font Awesome 7 Brands", "Font Awesome 6 Free", "Font Awesome 6 Brands", FontAwesome, "Material Icons", Roboto, Helvetica, Arial, sans-serif;
    font-size: 12px;
    min-height: 0px;
    font-weight: 700;
}

window#waybar {
    background: transparent;
}

tooltip {
    font-size: 13px;
    border: 2px solid rgba(90,90,90,0.3);
    border-radius: 16px;
    background-color: rgba(40, 40, 40, 0.8);
    padding:8px 12px;
    margin:0px;
}

tooltip label {
  color: @on_surface;
}


#workspaces {
    font-size: 10px;
    padding: 2px 0px;
    margin: 5px 0px 5px 0px;
    border-radius: 150px;   
}



#workspaces button {
    color: rgb(230, 230, 230);
    min-width: 1px;
    padding: 5px 7px 2px;
    border-radius: 500px;
    margin: 4px 3px;
    background:  rgba(90,90,90,0.3) ;
    border-bottom: 0px solid transparent;
    border-left: 1px solid transparent;
    border-right: 1px solid transparent;
}




#workspaces button.active {
    color: rgba(66, 66, 66, 0.896);
    border-radius: 500px;
    background: @primary;
    border-left: 14px solid transparent;
    border-right: 14px solid transparent;
    transition: all 0.25s ease-out;
}



#clock {
    padding: 3px 10px 0px;
    margin: 8px 7px 10px 0px;
    border-radius: 70px;
    background-color: rgba(90,90,90,0.3);
    color:rgb(230, 230, 230);
}


#battery {
    border-top-right-radius: 70px;
    border-bottom-right-radius: 70px;
    font-size: 17px;
    padding: 2px 13px 2px 6px;
    margin: 8px 10px 10px 0px;
    background-color: rgba(90,90,90,0.3);
    color: rgb(230, 230, 230);
}

#battery.full {
    color:lightgreen;
}



#battery.critical:not(.charging) {
    color: #f53c3c;
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}



#network {
    border-top-left-radius: 70px;
    border-bottom-left-radius: 70px;
    padding: 2px 15px 2px 10px;
    margin: 8px 0px 10px 0px;
    background-color: rgba(90,90,90,0.3);
    color:rgb(230, 230, 230);
}




#pulseaudio {
    padding: 2px 16px 2px 5px;
    font-size: 14px;
    margin: 8px 0px 10px 0px;
    background-color: rgba(90,90,90,0.3);
    color: rgb(230, 230, 230);
}


#pulseaudio.bluetooth {
    font-size: 16px;
    margin: 0px;
    padding: 2px 10px;

}


#power-profiles-daemon {
    padding: 2px 10px;
    font-size: 14px;
    margin: 0px;
}

#power-profiles-daemon.power-saver {
    padding: 2px 11px 2px 8px;
    font-size: 14px;
    margin: 0px;
    color:lightgreen;
}

#power-profiles-daemon.performance {
    padding: 2px 10px 2px 10px;
    font-size: 14px;
    margin: 0px;
    color:yellow;
}

#power-profiles-daemon.balanced {
    padding: 2px 14px 2px 7px;
    font-size: 14px;
    margin: 0px;
    color:white;
}



#memory {
    border-top-right-radius: 70px;
    border-bottom-right-radius: 70px;
    padding: 1px 12px ;
    /*font-size: 12px;*/
    margin: 8px 4px 10px 0px;;
    color: rgb(230, 230, 230);
    background-color: rgba(90,90,90,0.3);
}


#tray {
    padding: 11px 5px;
    margin: 0px 0px 2px 4px;
    border-radius: 70px;
}


#custom-appmenu {
    border-top-left-radius: 70px;
    border-bottom-left-radius: 70px;
    font-size: 18px;
    padding: 0px 8px 0px 13px;
    margin: 8px 0px 10px 6px;
    background-color: rgba(90,90,90,0.3);
    color:@primary; 
}

